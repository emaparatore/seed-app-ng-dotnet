{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "SeedApp",
    "Audience": "SeedApp",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "Enrich": ["FromLogContext"],
    "Properties": {
      "Application": "SeedApp"
    }
  },
  "CorsSettings": {
    "AllowedOrigins": ["http://localhost:4200"]
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromEmail": "noreply@seedapp.com",
    "FromName": "Seed App",
    "Security": "StartTls"
  },
  "Client": {
    "BaseUrl": "http://localhost:4200"
  },
  "Privacy": {
    "ConsentVersion": "1.0"
  },
  "DataRetention": {
    "SoftDeletedUserRetentionDays": 30,
    "RefreshTokenRetentionDays": 7,
    "AuditLogRetentionDays": 365,
    "CleanupIntervalHours": 24
  },
  "Modules": {
    "Payments": {
      "Enabled": false,
      "Provider": ""
    }
  },
  "Stripe": {
    "SecretKey": "",
    "PublishableKey": "",
    "WebhookSecret": ""
  },
  "AllowedHosts": "*"
}
