# =============================================================================
# Environment variables for production deployment
# Copy this file to docker/.env and fill in the values with production secrets
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=seeddb
POSTGRES_USER=seed
POSTGRES_PASSWORD=<strong-password-here>

# --- ASP.NET Core API ---
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Host=postgres;Database=seeddb;Username=seed;Password=<strong-password-here>
JwtSettings__Secret=<random-string-at-least-32-characters>
AllowedHosts=*

# --- SMTP (opzionale — se vuoto, le email vengono loggate in console) ---
Smtp__Host=
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=noreply@yourdomain.com
Smtp__FromName=Seed App
Smtp__UseSsl=true

# --- VPS Deployment (docker-compose.deploy.yml) ---
DOMAIN_NAME=yourdomain.com
GHCR_OWNER=your-github-username
IMAGE_TAG=latest
