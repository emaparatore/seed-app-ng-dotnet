# =============================================================================
# Environment variables for Docker Compose
# Copy this file to .env:  cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=seeddb
POSTGRES_USER=seed
POSTGRES_PASSWORD=seed_password

# --- ASP.NET Core API ---
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Database=seeddb;Username=seed;Password=seed_password
JwtSettings__Secret=YourSuperSecretKeyThatIsAtLeast32CharactersLong_ForDevelopmentOnly!
AllowedHosts=*
