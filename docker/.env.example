# =============================================================================
# Environment variables for Docker Compose
# Copy this file to .env:  cp .env.example .env
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=seeddb
POSTGRES_USER=seed
POSTGRES_PASSWORD=seed_password

# --- ASP.NET Core API ---
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Database=seeddb;Username=seed;Password=seed_password
JwtSettings__Secret=YourSuperSecretKeyThatIsAtLeast32CharactersLong_ForDevelopmentOnly!
AllowedHosts=*

# --- SuperAdmin seeding (first startup) ---
SuperAdmin__Email=admin@seedapp.local
SuperAdmin__Password=Admin123!
SuperAdmin__FirstName=Super
SuperAdmin__LastName=Admin

# --- Sandbox (Claude Code config mount) ---
# Su WSL: path Windows montato via /mnt/c (obbligatorio se .claude e' sul lato Windows)
# CLAUDE_CONFIG_DIR=/mnt/c/Users/<tuo-username>
#
# Su Windows (Git Bash / PowerShell): lascia commentato, usa $HOME di default
# CLAUDE_CONFIG_DIR=
